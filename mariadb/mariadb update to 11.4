


dnf --assumeyes  update ;


###    https://kb.filewave.com/books/linux-tips-and-tricks/page/upgrading-or-updating-mariadb-on-almalinux-9 

dnf  list installed | grep --ignore-case  maria   ;   ## optional 
ls -l  /etc/yum.repos.d/MariaDB.repo              ;   ## optional

cat  <<END   >  /etc/yum.repos.d/MariaDB.repo;
[mariadb]
name = MariaDB
baseurl = http://yum.mariadb.org/11.4/rhel10-amd64
module_hotfixes=1
gpgkey=https://yum.mariadb.org/RPM-GPG-KEY-MariaDB
gpgcheck=1
END

dnf  --assumeyes  install MariaDB-server   MariaDB-devel;
dnf  list installed | grep --ignore-case  maria   ;   ## optional 
systemctl  enable    mariadb.service  ;
systemctl  start     mariadb.service  ;

echo  'SELECT VERSION() "Version:" ;' | mariadb     ;


