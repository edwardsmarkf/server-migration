#!  /bin/bash
#
#           02_php_testing.bsh
#
#    2026-03-28  -- initial writing from 02_phpImageMagick.bsh
#    2026-04-06  -- added new index.php with phpinfo() and all links

DOMAIN=zzyzxzzyzx.com ;  

cp  --verbose    /root/server-migration/php/index.php         /home/${DOMAIN}/public_html/   ;

chown  --verbose ${DOMAIN}:${DOMAIN}      /home/${DOMAIN}/public_html/phpinfo.php ;  ##
chmod  --verbose 755                      /home/${DOMAIN}/public_html/phpinfo.php ;  ##


cat <<END_OF_SCRIPT > /home/${DOMAIN}/public_html/imageMagickTest.php ;   ##2025-08-13 - new location!
<?php
    \$image = new Imagick();
    \$image->newImage(100, 100, new ImagickPixel('red'));
    \$image->setImageFormat('png');
    header('Content-type: image/png');
    echo \$image;
?>
END_OF_SCRIPT

chown  --verbose ${DOMAIN}:${DOMAIN}      /home/${DOMAIN}/public_html/*.php ;  ## 2025-08-13
chmod  --verbose 755                      /home/${DOMAIN}/public_html/*.php ;  ## 2025-08-13
ls  -l                                     /home/${DOMAIN}/public_html/                   ;



cat  <<END  ;
please try  http://${DOMAIN}/index.php   in your browser:
be sure to look for both the magick section AND the magicwand section near the bottom!!
and please try  http://${DOMAIN}/imageMagickTest.php
END


exit 1;







########################################################################################################
########################################################################################################
########################################################################################################
########################################################################################################
########################################################################################################


cat <<END_OF_PHPINFO  >  /home/${DOMAIN}/public_html/phpinfo.php           ;
<?php
        echo    '<br />'
        .       'Server User: '
        .       \$_SERVER['USER']
        .       '<br />'
        .       'Current script owner: '
        .       get_current_user()
        .       '<br />'
        .       'The current date and time is: '
        .       date('Y-m-d H:i:s')
        .       '<br />'
        .       '<br />'
        ;
        phpinfo();
?>
END_OF_PHPINFO



