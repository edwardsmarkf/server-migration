#!  /bin/bash  -w
#
#    Master_Installer.bsh      2026-01-30
#
#    2026-06-08  - added a php version variable
#    2026-06-13  - backed off to 8.5 because of REMI
#
PHP_LATEST_RELEASE=8.5    ;   ##  add variable 2026-06-08

bash -vx  ~/server-migration/php/00_php_install_after_webmin.bsh ${PHP_LATEST_RELEASE}                                           \
                                                              &> ~/server-migration/php/00_php_install_after_webmin.bsh.log      ;
tail                                                             ~/server-migration/php/00_php_install_after_webmin.bsh.log      ;

bash  -vx  ~/server-migration/php/01_php_install_RL.bsh       &>  ~/server-migration/php/01_php_install_RL.bsh.log               ;
tail                                                              ~/server-migration/php/01_php_install_RL.bsh.log               ;

bash  -vx  ~/server-migration/php/02_phpImageMagick.bsh       &>  ~/server-migration/php/02_phpImageMagick.bsh.log               ;
tail                                                              ~/server-migration/php/02_phpImageMagick.bsh.log               ;

bash  -vx  ~/server-migration/php/03_php_composer.bsh         &>  ~/server-migration/php/03_php_composer.bsh.log                 ;
tail                                                              ~/server-migration/php/03_php_composer.bsh.log                 ;

exit ;

#
