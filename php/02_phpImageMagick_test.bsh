#!  /bin/bash
#
#           02_phpImageMagick_test.bsh
#
#    2026-03-28  -- initial writing from 02_phpImageMagick.bsh

DOMAIN=zzyzxzzyzx.com ;  

echo '<?php phpinfo(); ?>'     >  /home/${DOMAIN}/public_html/phpinfo.php

chown  --verbose ${DOMAIN}:${DOMAIN}      /home/${DOMAIN}/public_html/phpinfo.php ;  ##
chmod  --verbose 755                      /home/${DOMAIN}/public_html/phpinfo.php ;  ##


cat <<END_OF_SCRIPT > /home/${DOMAIN}/public_html/imageMagickTest.php ;   ##2025-08-13 - new location!
<?php
    \$image = new Imagick();
    \$image->newImage(100, 100, new ImagickPixel('red'));
    \$image->setImageFormat('png');
    header('Content-type: image/png');
    echo \$image;
?>
END_OF_SCRIPT

chown  --verbose ${DOMAIN}:${DOMAIN}      /home/${DOMAIN}/public_html/imageMagickTest.php ;  ## 2025-08-13
chmod  --verbose 755                      /home/${DOMAIN}/public_html/imageMagickTest.php ;  ## 2025-08-13
ls  -l                                     /home/${DOMAIN}/public_html/                   ;



cat  <<END  ;
please try  http://${DOMAIN}/phpinfo.php   in your browser:
be sure to look for both the magick section AND the magicwand section near the bottom!!
and please try  http://${DOMAIN}/imageMagickTest.php
END


exit 1;







