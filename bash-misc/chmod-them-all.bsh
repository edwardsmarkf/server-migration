#!  /bin/bash  
#
#    chmod-them-all.bsh    2026-03-24
#
#

while  read -r   domain; do
        echo ${domain}                                                          ;
        chmod ---recursive --silent  ${domain}:${domain}      ${domain} ;
done  <<END_OF_DOMAINS
accentreduction.online
ajcomptonpesl.com
comptonpeslonline.com
comptonpeslonline.info
edwardsmark.com
englishwithoutaccent.com
gordonredwards.com
slrh.org
virtualaska.com
END_OF_DOMAINS
