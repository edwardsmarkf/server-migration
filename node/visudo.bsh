## 2016-02-19     added by /edwardsmarkf/server-migration/node/visudo
comptonpeslonline.com   ALL=(ALL:ALL)   NOPASSWD:       /usr/sbin/csf
comptonpeslonline.com   ALL=(ALL:ALL)   NOPASSWD:       /bin/sh




##  2026-03-04 - added  new location for csf  new file chown and mv  (why do we need these two??_
comptonpeslonline.com   ALL=(ALL:ALL)   NOPASSWD:       /bin/chown
comptonpeslonline.com   ALL=(ALL:ALL)   NOPASSWD:       /bin/file
comptonpeslonline.com   ALL=(ALL:ALL)   NOPASSWD:       /bin/mv
